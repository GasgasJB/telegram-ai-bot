# Telegram Bot Token (get it from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Anthropic API Key (get it from https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model to use (optional, defaults to claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# Maximum tokens for Claude responses (optional, defaults to 1024)
MAX_TOKENS=1024
